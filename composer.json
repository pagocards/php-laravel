{
  "name": "pagocards/php-laravel",
  "description": "Official PHP Laravel SDK for Pagocards card issuance and wallet APIs",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Pagocards LLC",
      "email": "support@pagocards.com",
      "homepage": "https://pagocards.com"
    }
  ],
  "keywords": [
    "pagocards",
    "card-issuance",
    "virtual-cards",
    "mastercard",
    "visa",
    "api",
    "laravel"
  ],
  "homepage": "https://github.com/pagocards/php-laravel",
  "support": {
    "issues": "https://github.com/pagocards/php-laravel/issues",
    "source": "https://github.com/pagocards/php-laravel",
    "email": "cs@pagocards.com"
  },
  "require": {
    "php": "^8.1",
    "guzzlehttp/guzzle": "^7.0",
    "illuminate/support": "^8.0|^9.0|^10.0|^11.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0",
    "mockery/mockery": "^1.5"
  },
  "autoload": {
    "psr-4": {
      "Pagocards\\SDK\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Pagocards\\SDK\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Pagocards\\SDK\\ServiceProvider"
      ]
    },
    "branch-alias": {
      "dev-main": "1.x-dev"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test-coverage": "phpunit --coverage-html ./coverage"
  },
  "config": {
    "sort-packages": true
  }
}

